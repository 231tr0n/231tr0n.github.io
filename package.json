{
	"name": "231tr0n.github.io",
	"private": true,
	"version": "1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"show-deps-updates": "npm-check-updates",
		"update-deps": "npx --yes npm-check-updates -u && npm install",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --list-different --write .",
		"lint": "npm run check && prettier --check . && eslint .",
		"lint-fix": "eslint --fix . && prettier --list-different --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"ci": "npm install && npm run lint && npm run build && npm run test"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/css": "^1.0.0",
		"@eslint/js": "^10.0.1",
		"@html-eslint/eslint-plugin": "^0.58.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.5.0",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.4.0",
		"npm-check-updates": "^19.6.5",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"rollup-plugin-visualizer": "^7.0.1",
		"svelte": "^5.54.1",
		"svelte-check": "^4.4.5",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.2",
		"vite": "^8.0.1",
		"vitest": "^4.1.1"
	},
	"dependencies": {
		"ace-code": "^1.43.6"
	}
}
